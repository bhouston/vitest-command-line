{
  "name": "vitest-command-line",
  "version": "0.7.0",
  "type": "module",
  "description": "Helpers and matchers for testing command-line tools with Vitest",
  "keywords": [
    "vitest",
    "cli",
    "command-line",
    "testing",
    "subprocess"
  ],
  "license": "MIT",
  "author": "Ben Houston",
  "homepage": "https://github.com/bhouston/vitest-command-line#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhouston/vitest-command-line.git"
  },
  "bugs": {
    "url": "https://github.com/bhouston/vitest-command-line/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json --preserveWatchOutput",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "format": "biome check --write .",
    "make-release": "node scripts/make-release.mjs ."
  },
  "peerDependencies": {
    "vitest": ">=4 <5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
